{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/PLACEHOLDER/llm-erd-benchmark/schemas/ground_truth.schema.json",
  "title": "Ground-Truth ERD Model",
  "description": "Unified schema for expert-curated ground-truth ERD models used as the scoring reference of the LLM conceptual-modeling benchmark. The ground-truth JSON files are the single source of truth for all expected counts and matching decisions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["model", "entities", "relationships"],
  "properties": {

    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "description", "source"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "source": { "type": "string" }
      }
    },

    "entities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entity" }
    },

    "relationships": {
      "type": "array",
      "items": { "$ref": "#/$defs/relationship" }
    }
  },

  "$defs": {

    "cardinalityValue": {
      "type": "string",
      "enum": ["1", "0..1", "N", "0..N", "1..N"]
    },

    "attributeReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity", "attribute"],
      "properties": {
        "entity": { "type": "string", "minLength": 1 },
        "attribute": { "type": "string", "minLength": 1 }
      }
    },

    "attribute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "nullable": { "type": "boolean" },
        "semanticType": { "type": "string" },
        "generated": {
          "type": "boolean",
          "description": "True when the attribute is a surrogate key materialized in the synthetic CSV rather than a natural business attribute."
        },
        "unit": { "type": "string" },
        "references": {
          "$ref": "#/$defs/attributeReference",
          "description": "Present when (and only when) semanticType is ForeignKey: the referenced entity/attribute."
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Expert-curated accepted synonyms for scoring (frozen before any run)."
        }
      },
      "if": {
        "properties": { "semanticType": { "const": "ForeignKey" } },
        "required": ["semanticType"]
      },
      "then": { "required": ["references"] }
    },

    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "primaryKey", "attributes"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "businessDescription": { "type": "string" },
        "primaryKey": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "candidateKeys": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "attributes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/attribute" }
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Expert-curated accepted synonyms for scoring (frozen before any run)."
        }
      }
    },

    "foreignKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity", "attributes", "references"],
      "properties": {
        "entity": {
          "type": "string",
          "minLength": 1,
          "description": "Entity holding the FK columns (always the relationship target/child side)."
        },
        "attributes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "FK column(s); more than one entry means a composite foreign key."
        },
        "references": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entity", "attributes"],
          "properties": {
            "entity": { "type": "string", "minLength": 1 },
            "attributes": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },

    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source", "target", "cardinality", "foreignKey", "mandatory"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "source": {
          "type": "string",
          "minLength": 1,
          "description": "Parent ('one') side of the relationship."
        },
        "target": {
          "type": "string",
          "minLength": 1,
          "description": "Child ('many') side of the relationship."
        },
        "cardinality": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "target"],
          "properties": {
            "source": { "$ref": "#/$defs/cardinalityValue" },
            "target": { "$ref": "#/$defs/cardinalityValue" }
          }
        },
        "role": {
          "type": "string",
          "description": "Disambiguates multiple relationships between the same entity pair (e.g., Departure vs Arrival); matched via the FK column."
        },
        "foreignKey": { "$ref": "#/$defs/foreignKey" },
        "mandatory": {
          "type": "boolean",
          "description": "False when the child-side FK is nullable (optional participation)."
        }
      }
    }
  }
}
