{
  "experiment": "dke-llm-erd-oneshot",
  "protocol_version": "0.96",
  "prompt_version": "2.1 (adds an explicit anti-fabrication instruction to the base prompt; supersedes 2.0)",

  "models": [
    {
      "key": "mistral",
      "provider": "mistral",
      "model_env": "MISTRAL_MODEL",
      "key_env": "MISTRAL_API_KEY",
      "default_model": "mistral-small-latest",
      "tier": "free"
    },
    {
      "key": "gemini",
      "provider": "google",
      "model_env": "GEMINI_MODEL",
      "key_env": "GEMINI_API_KEY",
      "default_model": "gemini-2.5-flash",
      "tier": "paid"
    }
  ],

  "datasets": ["airlines", "manufacturing"],
  "design": "v2: full factorial over knowledge factors {domain, dictionary, rules} (2^3) x header levels {meaningful, cryptic, none} = 24 conditions (see scripts/design.py).",
  "temperatures": [0.0, 0.2, 0.5],
  "replicates": [1, 2, 3],

  "decoding": {
    "top_p": 1.0,
    "max_tokens": 4096,
    "seed_base": 41,
    "seed_policy": "seed = 42 for every replicate at temperature 0 (byte-identical requests, measures provider determinism); seed = seed_base + replicate (42/43/44) for temperature > 0",
    "gemini_thinking_budget": 0
  },

  "sampling": {
    "max_cardinality": 50,
    "min_occurrences": 2,
    "group_keys": {
      "airlines": ["flight_number", "flight_date"],
      "manufacturing": ["n_order"]
    }
  },

  "transport": {
    "max_retries": 5,
    "backoff_base_seconds": 2,
    "mistral_min_interval_seconds": 1.0
  },

  "paths": {
    "prompts_rendered": "prompts/rendered",
    "results_raw": "results/raw",
    "results_parsed": "results/parsed",
    "results_metrics": "results/metrics",
    "results_aggregate": "results/aggregate"
  }
}
